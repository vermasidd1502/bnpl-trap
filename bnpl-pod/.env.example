# ---------------------------------------------------------------------------
# BNPL Pod — secrets template. Copy to .env and fill in. Never commit .env.
# ---------------------------------------------------------------------------

# --- LLMs ---
# NVIDIA NIM (hosted Nemotron) — OpenAI-compatible endpoint.
NVIDIA_NIM_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxx
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
# Small-tier model (Data + Macro agents) — fast, cheap, no reasoning trace.
NVIDIA_NIM_MODEL_SMALL=nvidia/nemotron-mini-4b-instruct
# Heavy-tier model (Quant + Risk Manager) — Nemotron-3 Super 120B MoE with
# thinking mode on. Supports `reasoning_content` streaming + `reasoning_budget`.
NVIDIA_NIM_MODEL_HEAVY=nvidia/nemotron-3-super-120b-a12b

# Gemini fallback (Google AI Studio) — free tier, OpenAI-compatible endpoint.
# Get a key at https://aistudio.google.com/apikey  (no credit card required).
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_MODEL_SMALL=gemini-2.5-flash
GEMINI_MODEL_HEAVY=gemini-2.5-pro

# --- Data APIs ---
# FRED (St. Louis Fed) — free, https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# SEC EDGAR requires a declared User-Agent: "Your Name youremail@example.com"
# This is an SEC rule, not an API key. Be truthful.
SEC_EDGAR_UA=Siddharth Verma sverma24@illinois.edu

# Reddit PRAW — https://www.reddit.com/prefs/apps  (create "script" app)
REDDIT_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxx
REDDIT_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
REDDIT_USER_AGENT=bnpl-pod/0.1 by u/yourusername

# --- Infra ---
# DuckDB lives at a local file path; no daemon.
DUCKDB_PATH=./data/warehouse.duckdb
# Milvus (docker-compose).
MILVUS_HOST=localhost
MILVUS_PORT=19530

# --- Pod config ---
# Force a specific provider. Values: "nim" (default), "gemini", or unset.
# Useful for debugging and for A/B contract tests. Takes precedence over
# automatic failover, so set sparingly.
LLM_FORCE_PROVIDER=
# Set to "true" in CI / offline testing to skip live network calls.
POD_OFFLINE_MODE=false
