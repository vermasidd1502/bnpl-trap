# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Fonts (large binaries, not needed in repo — users fetch locally)
fonts/

# Claude Code runtime artifacts (project launch config is tracked; lock files are not)
.claude/scheduled_tasks.lock
.claude/sessions/
.claude/cache/

# Per-machine Claude workspace noise inside the pod tree (never committed)
bnpl-pod/.claude/

# Local rescue backups (paranoia copies of the working tree; never committed)
bnpl-pod-rescue-backup-*/

# Design-brief archives (kept locally, not in version control)
BNPL pod design.zip
_design_unpack/
